# Environment template for world.nol.com foundation
# Copy to `.env.local` for local development and configure matching values in Vercel.
# Keep server-only secrets out of client bundles.

# --------------------------------------------------
# App runtime
# --------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,ko

# --------------------------------------------------
# Neon / PostgreSQL
# --------------------------------------------------
# Pooled connection for serverless runtime queries on Vercel.
DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require

# Direct connection for migrations, schema tooling, or local admin scripts.
DATABASE_DIRECT_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require

# Optional explicit role/env hints for debugging or observability.
DATABASE_PROVIDER=neon
DATABASE_BRANCH=main
DATABASE_SSL_MODE=require

# --------------------------------------------------
# Admin auth foundation
# --------------------------------------------------
ADMIN_AUTH_MODE=mock
ADMIN_SESSION_COOKIE_NAME=world_admin_session
ADMIN_SESSION_COOKIE_SECURE=false
ADMIN_SESSION_TTL_SECONDS=1209600
ADMIN_SESSION_SECRET=change-me
ADMIN_ALLOWED_EMAIL_DOMAINS=
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_NAME=Admin User
ADMIN_BOOTSTRAP_ROLE=super_admin
# Password for bootstrap admin user (used in credentials mode).
# In mock mode any non-empty password works for the bootstrap email.
ADMIN_BOOTSTRAP_PASSWORD=changeme-dev-only
# HMAC secret for signing session tokens. REQUIRED in production.
ADMIN_SESSION_SECRET=

# Optional future auth integration knobs.
AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:3000
AUTH_SECRET=change-me-auth-secret

# --------------------------------------------------
# Vercel / deployment integration
# --------------------------------------------------
VERCEL_ENV=development
VERCEL_PROJECT_PRODUCTION_URL=
VERCEL_GIT_COMMIT_REF=

# --------------------------------------------------
# Media / storage placeholders
# --------------------------------------------------
MEDIA_STORAGE_PROVIDER=vercel_blob
BLOB_READ_WRITE_TOKEN=

# --------------------------------------------------
# Admin revalidation / internal actions
# --------------------------------------------------
REVALIDATE_SECRET=change-me-revalidate-secret
